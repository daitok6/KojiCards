# Database (Neon / Vercel Marketplace Postgres)
DATABASE_URL=

# Vercel Blob
BLOB_READ_WRITE_TOKEN=

# Auth.js
AUTH_SECRET=

# Admin credentials (used only by db:seed)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# Resend (contact form email delivery)
RESEND_API_KEY=
CONTACT_TO_EMAIL=

# Vendor contact info (public — shown on the Contact page)
NEXT_PUBLIC_VENDOR_EMAIL=contact@example.com
NEXT_PUBLIC_VENDOR_PHONE=+1 (555) 000-0000
NEXT_PUBLIC_VENDOR_WHATSAPP=15550000000
NEXT_PUBLIC_VENDOR_INSTAGRAM=https://instagram.com/yourshop
NEXT_PUBLIC_VENDOR_ADDRESS=123 Card Street, City, State 00000
NEXT_PUBLIC_GOOGLE_MAPS_EMBED=https://www.google.com/maps/embed?pb=...
