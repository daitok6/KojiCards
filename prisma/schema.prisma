generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Card {
  id        String      @id @default(cuid())
  name      String
  imageUrl  String
  game      String
  set       String
  rarity    String
  condition String
  price     Decimal?
  stock     Int         @default(1)
  featured  Boolean     @default(false)
  // --- New catalogue fields ---
  cardNumber    String?  // Collector / set number e.g. "4/102"
  finish        String   @default("Normal")   // Normal · Holo · Reverse Holo · Foil · Other
  language      String   @default("English")  // English · Japanese · Chinese · Korean · French · German · Spanish · Italian · Other
  firstEdition  Boolean  @default(false)
  graded        Boolean  @default(false)
  gradingCompany String? // PSA · BGS · CGC · SGC · Other
  grade         String?  // e.g. "10", "9.5" — string to allow half grades
  certNumber    String?  // Grading cert / serial number
  sku           String?  // Vendor stock code
  artist        String?  // Card illustrator
  releaseYear   Int?     // Set release year e.g. 1999
  status        String   @default("available") // "available" | "reserved" | "sold"
  details       String?  // Free-text notes (whitening, misprint, signed, etc.)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  media     CardMedia[]

  @@index([status])
}

model CardMedia {
  id        String   @id @default(cuid())
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  url       String
  type      String   // "image" | "video"
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([cardId])
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String
}

model VendorInfo {
  id        String   @id @default("singleton")
  email     String   @default("")
  phone     String   @default("")
  whatsapp  String   @default("")
  instagram String   @default("")
  address   String   @default("")
  mapsEmbed String   @default("")
  updatedAt DateTime @updatedAt
}

model Event {
  id          String    @id @default(cuid())
  name        String
  startDate   DateTime
  endDate     DateTime?              // set for multi-day shows
  city        String
  venue       String?
  booth       String?                // booth / table number
  description String?
  link        String?                // convention's own site
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([startDate])
}

model Announcement {
  id        String   @id @default("singleton")
  message   String   @default("")
  link      String   @default("")
  active    Boolean  @default(false)
  updatedAt DateTime @updatedAt
}
